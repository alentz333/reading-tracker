# Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Only needed to run the seed script (npm run seed) — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Seed values — used once by scripts/seed.ts
SEED_BABY_NAME=Lily
SEED_BABY_DOB=2025-12-01
SEED_USER_EMAIL=parents@example.com
SEED_USER_PASSWORD=change-me-after-first-login
